# ─────────────────────────────────────────────────────────────────────────────
# .gitignore for the Sentinel project
# ─────────────────────────────────────────────────────────────────────────────

# Build outputs
dist/
/sentinel
*.exe

# Test coverage artifacts
coverage.out
coverage.html

# Go tool cache
vendor/

# Editor & OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/
.cursor/
.windsurf/
.notes/
.clinerules
.cursorrules
.windsurfrules
*.swp
*.swo
*~

# Sensitive config (never commit real credentials)
.sentinel.yaml
!.sentinel.yaml.example

# Agent instruction cache & lockfiles
.agents/
skills-lock.json

# Cloned local repositories
nexusfi-web/

# Exclude findings pages until disclosures are closed and patched
docs/wild.html
docs/wild-ar.html


